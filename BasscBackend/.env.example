# superSat 后端环境变量模板（复制为 .env 后填写，勿提交 .env）

# Django
SECRET_KEY=change-me-to-a-random-secret-key
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# 数据库（三选一，本地开发默认 SQLite，无需配置）
# 生产：Railway PostgreSQL
# DATABASE_URL=postgresql://user:pass@host:5432/dbname
# 本地 MySQL：USE_MYSQL=1 并填写下方 DB_* 
# USE_MYSQL=1
# DB_NAME=supersat_db
# DB_USER=root
# DB_PASSWORD=
# DB_HOST=127.0.0.1
# DB_PORT=3306

# Railway Bucket（S3 兼容）- 图片/视频上传
# 生产：在 superSat_BE Variables 里从 Bucket 服务 Reference 这 4 个（推荐）：
#   ACCESS_KEY_ID / SECRET_ACCESS_KEY / ENDPOINT / BUCKET
# 注意：BUCKET 是 S3 API 桶名（如 xxx-abc123），不是画布上的 RAILWAY_BUCKET_NAME 显示名
ACCESS_KEY_ID=
SECRET_ACCESS_KEY=
ENDPOINT=https://t3.storageapi.dev
BUCKET=
# 或使用 RAILWAY_BUCKET_* 前缀（同上含义）：
# RAILWAY_BUCKET_ACCESS_KEY=
# RAILWAY_BUCKET_SECRET_KEY=
# RAILWAY_BUCKET_ENDPOINT=https://t3.storageapi.dev
# 若存储有单独公网访问地址可设置（可选）
# RAILWAY_BUCKET_PUBLIC_BASE=https://xxx.public.railway.app

# 无素材时使用的默认占位图（可选）
# DEFAULT_PLACEHOLDER_IMAGE=/static/default-placeholder.png

# CORS（部署时填写前端域名，逗号分隔）
# CORS_ALLOWED_ORIGINS=https://your-frontend.example.com
